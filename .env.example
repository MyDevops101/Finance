# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-openssl-rand-base64-32

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/Eagle_quantitative?schema=public

# OAuth providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Market data providers
# --- Keyless sources (live out of the box): CoinGecko, open.er-api (FX),
#     SEC EDGAR (filings/insider), GDELT (news). No keys required. ---
# --- Add keys below to light up the remaining live feeds. ---
ALPHA_VANTAGE_API_KEY=        # Stock OHLCV / daily candles
FINNHUB_API_KEY=              # Real-time quotes, earnings calendar
TWELVE_DATA_API_KEY=          # Real-time quotes & intraday candles
POLYGON_API_KEY=              # Quotes & daily candles (limited free tier)
FMP_API_KEY=                  # Fundamentals (income/balance/cash flow), screener, factors
FRED_API_KEY=                 # US macro series (yields, CPI, unemployment)
TRADIER_API_KEY=              # Options chains
TRADIER_BASE_URL=https://sandbox.tradier.com/v1
NASDAQ_DATA_LINK_API_KEY=     # Commodities (LBMA gold/silver + datasets)
NEWS_API_KEY=                 # Optional news fallback (GDELT covers news keyless)
GNEWS_API_KEY=
HUGGINGFACE_API_KEY=
# Keyless & live already: ECB Data Portal (EU macro) — no key needed.

# SEC EDGAR requires a descriptive User-Agent with contact info (their policy).
SEC_EDGAR_USER_AGENT=Eagle Quantitative Terminal your-email@example.com

# OpenAI-compatible inference endpoint
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_API_KEY=
AI_PROVIDER_MODEL=gpt-4.1-mini

# Cache and rate limiting
MARKET_DATA_CACHE_SECONDS=300
NEWS_CACHE_SECONDS=900
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

